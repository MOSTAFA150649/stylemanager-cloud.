{
  "name": "stylemanager-desktop",
  "version": "1.0.0",
  "description": "Desktop version of StyleManager",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "dist": "npm run build:frontend && npm run build:backend && electron-builder"
  },
  "build": {
    "appId": "com.stylemanager.app",
    "win": {
      "target": ["nsis", "zip"]
    },
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "main.js",
      "backend/dist/**/*",
      "backend/package.json",
      "backend/prisma/**/*",
      "backend/public/**/*",
      "backend/node_modules/.prisma/client/**/*",
      "frontend/dist/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8"
  }
}
