{
  "name": "stylemanager-desktop",
  "version": "1.0.0",
  "description": "Desktop version of StyleManager",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && npm install && npm run build",
    "postinstall": "cd backend && npx prisma generate",
    "dist": "npm run build:frontend && npm run build:backend && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0"
  }
}

