# Config Serveur
PORT=5000
NODE_ENV=production

# Base de Données Cloud (PostgreSQL)
# Obtenez-la sur Supabase ou Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Sécurité
JWT_SECRET="votre_secret_tres_long_et_aleatoire"

# Notifications WhatsApp (API Meta Cloud)
# Obtenez-les sur developers.facebook.com
WHATSAPP_TOKEN="votre_acces_token"
WHATSAPP_PHONE_NUMBER_ID="votre_id_numero"
RECIPIENT_PHONE_NUMBER="212xxxxxxxxx" # Numéro qui recevra les notifications
